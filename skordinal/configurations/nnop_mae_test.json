{
    "general_conf": {
        "basedir": "skordinal/datasets/data",
        "datasets": ["balance-scale"],
        "hyperparam_cv_nfolds": 3,
        "jobs": 10,
        "input_preprocessing": "std",
        "output_folder": "my_runs/",
        "metrics": ["accuracy", "mean_absolute_error", "mean_zero_one_error"],
        "cv_metric": "neg_mean_absolute_error"
    },
    "configurations": {
        "NNOP-MAE": {
            "classifier": "NNOP",
            "parameters": {
                "epsilon_init": 0.5,
                "n_hidden": [5, 10, 20, 30, 40, 50],
                "max_iter": [250, 500],
                "lambda_value": [0, 0.01, 1]
            }
        }
    }
}
